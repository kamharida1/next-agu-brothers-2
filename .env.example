# Copy to .env.local and fill in values.
# Required for local dev / Vercel preview / production.

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
AUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Database ────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/agu-brothers

# ── Auth (NextAuth v5) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: Facebook deauthorize webhook
FACEBOOK_CLIENT_SECRET=

# ── Cloudinary (images) ─────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
# Server-only (upload signing / admin)
CLOUDINARY_API_SECRET=

# ── Paystack (checkout) ─────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx

# ── Mailgun (order emails) ─────────────────────────────────────────
MAILGUN_API_KEY=
NEXT_PUBLIC_MAILGUN_DOMAIN=mg.yourdomain.com

# ── AI product generation (admin) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Product image search (Quick Add) ──────────────────────────────────
# https://serper.dev — Google Images API (2,500 free searches to start)
SERPER_API_KEY=

# ── Admin utilities ─────────────────────────────────────────────────
ADMIN_RESTORE_SECRET=change-me-in-production

# ── E2E tests (optional) ────────────────────────────────────────────
# PLAYWRIGHT_BASE_URL=https://www.agubrothers.com
